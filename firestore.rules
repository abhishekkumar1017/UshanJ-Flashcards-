rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: subjects
    // Fields: name, createdAt
    //
    // Collection: flashcards
    // Fields: front, back, subjectId, createdAt
    //
    // ===============================================================

    function isAuthenticated() {
      return true;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidSubject(data) {
      return hasRequiredFields(['name', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidDeck(data) {
      return hasRequiredFields(['name', 'subjectId', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.subjectId is string &&
             data.createdAt is timestamp;
    }

    function isValidFlashcard(data) {
      return hasRequiredFields(['front', 'back', 'deckId', 'subjectId', 'createdAt']) &&
             data.front is string && data.front.size() >= 1 && data.front.size() <= 500 &&
             data.back is string && data.back.size() >= 1 && data.back.size() <= 500 &&
             data.deckId is string &&
             data.subjectId is string &&
             data.createdAt is timestamp;
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow create: if isValidSubject(request.resource.data);
      allow update: if isValidSubject(request.resource.data) && 
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if true;
    }

    match /decks/{deckId} {
      allow read: if true;
      allow create: if isValidDeck(request.resource.data);
      allow update: if isValidDeck(request.resource.data) && 
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if true;
    }

    match /flashcards/{flashcardId} {
      allow read: if true;
      allow create: if isValidFlashcard(request.resource.data);
      allow update: if isValidFlashcard(request.resource.data) &&
                      request.resource.data.deckId == resource.data.deckId &&
                      request.resource.data.subjectId == resource.data.subjectId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if false; 
    }
    
    // Allow the connection test
    match /test/connection {
      allow read: if true;
    }
  }
}
